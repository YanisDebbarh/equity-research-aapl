    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mtick\n",
    "import yfinance as yf\n",
    "import os\n",
    "\n",
    "RAW_DIR = '../data/raw/'\n",
    "VIS_DIR = '../visuals/'\n",
    "\n",
    "# Charger les peers\n",
    "peers = pd.read_csv(f'{RAW_DIR}peers_comps.csv')\n",
    "\n",
    "# Ajouter Apple pour comparaison\n",
    "aapl  = yf.Ticker('AAPL').info\n",
    "aapl_row = pd.DataFrame([{\n",
    "    'Ticker'    : 'AAPL',\n",
    "    'Name'      : 'Apple Inc.',\n",
    "    'MarketCap' : round(aapl.get('marketCap',0)/1e12, 2),\n",
    "    'PE_Ratio'  : aapl.get('trailingPE'),\n",
    "    'Fwd_PE'    : aapl.get('forwardPE'),\n",
    "    'EV_EBITDA' : aapl.get('enterpriseToEbitda'),\n",
    "    'EV_Revenue': aapl.get('enterpriseToRevenue'),\n",
    "    'Beta'      : aapl.get('beta'),\n",
    "}])\n",
    "\n",
    "# AAPL en premier\n",
    "comps = pd.concat([aapl_row, peers], ignore_index=True)\n",
    "\n",
    "print('✅ Comps table loaded\\n')\n",
    "print(comps[['Ticker','Name','MarketCap',\n",
    "             'PE_Ratio','EV_EBITDA','EV_Revenue']].round(1).to_string(index=False))\n"
   ]
  },
