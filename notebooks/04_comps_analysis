    "fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
    "fig.suptitle('Apple — Trading Comps Analysis', \n",
    "             fontweight='bold', fontsize=13)\n",
    "\n",
    "# --- Graphique 1 : EV/EBITDA par company ---\n",
    "ax1 = axes[0]\n",
    "colors = ['#e74c3c' if t == 'AAPL' else '#3498db' \n",
    "          for t in comps['Ticker']]\n",
    "bars = ax1.bar(comps['Ticker'], comps['EV_EBITDA'], \n",
    "               color=colors, alpha=0.85)\n",
    "ax1.axhline(y=median_ev_ebitda, color='navy', \n",
    "            linestyle='--', lw=2,\n",
    "            label=f'Peer Median: {median_ev_ebitda:.1f}x')\n",
    "for bar, val in zip(bars, comps['EV_EBITDA']):\n",
    "    if pd.notna(val):\n",
    "        ax1.text(bar.get_x() + bar.get_width()/2, \n",
    "                 val + 0.5, f'{val:.1f}x',\n",
    "                 ha='center', fontsize=9, fontweight='bold')\n",
    "ax1.set_ylabel('EV/EBITDA')\n",
    "ax1.set_title('EV/EBITDA vs Peers', fontweight='bold')\n",
    "ax1.legend()\n",
    "\n",
    "# --- Graphique 2 : Implied prices ---\n",
    "ax2 = axes[1]\n",
    "methods = ['P/E', 'Fwd P/E', 'EV/EBITDA', 'EV/Revenue', 'Blended']\n",
    "prices  = [tp_pe, tp_fwd_pe, tp_ev_ebitda, tp_ev_rev, tp_comps]\n",
    "colors2 = ['#3498db','#3498db','#3498db','#3498db','#27ae60']\n",
    "\n",
    "bars2 = ax2.bar(methods, prices, color=colors2, alpha=0.85)\n",
    "ax2.axhline(y=aapl_info['currentPrice'], color='#e74c3c',\n",
    "            linestyle='--', lw=2,\n",
    "            label=f'Current: ${aapl_info[\"currentPrice\"]:.0f}')\n",
    "for bar, val in zip(bars2, prices):\n",
    "    ax2.text(bar.get_x() + bar.get_width()/2,\n",
    "             val + 2, f'${val:.0f}',\n",
    "             ha='center', fontsize=9, fontweight='bold')\n",
    "ax2.set_ylabel('Implied Price ($)')\n",
    "ax2.set_title('Comps-Implied Target Prices', fontweight='bold')\n",
    "ax2.legend()\n",
    "ax2.tick_params(axis='x', rotation=15)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(f'{VIS_DIR}04_comps.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('✅ Comps chart sauvegardé!')\n"
   ]
