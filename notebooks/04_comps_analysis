     ]
    }
   ],
   "source": [
    "# Médiane des peers (sans AAPL)\n",
    "peer_only = comps[comps['Ticker'] != 'AAPL']\n",
    "median_pe       = peer_only['PE_Ratio'].median()\n",
    "median_fwd_pe   = peer_only['Fwd_PE'].median()\n",
    "median_ev_ebitda= peer_only['EV_EBITDA'].median()\n",
    "median_ev_rev   = peer_only['EV_Revenue'].median()\n",
    "\n",
    "print(f'📊 Peer Medians:')\n",
    "print(f'   P/E         : {median_pe:.1f}x')\n",
    "print(f'   Fwd P/E     : {median_fwd_pe:.1f}x')\n",
    "print(f'   EV/EBITDA   : {median_ev_ebitda:.1f}x')\n",
    "print(f'   EV/Revenue  : {median_ev_rev:.1f}x')\n",
    "\n",
    "# Métriques Apple\n",
    "aapl_info   = yf.Ticker('AAPL').info\n",
    "shares_m    = aapl_info['sharesOutstanding'] / 1e6\n",
    "net_debt    = (aapl_info.get('totalDebt',0) - aapl_info.get('totalCash',0)) / 1e6\n",
    "ebitda_m    = aapl_info.get('ebitda', 0) / 1e6\n",
    "revenue_m   = aapl_info.get('totalRevenue', 0) / 1e6\n",
    "eps_ttm     = aapl_info.get('trailingEps', 0)\n",
    "eps_fwd     = aapl_info.get('forwardEps', 0)\n",
    "\n",
    "# Target prices\n",
    "tp_pe      = median_pe * eps_ttm\n",
    "tp_fwd_pe  = median_fwd_pe * eps_fwd\n",
    "tp_ev_ebitda = ((median_ev_ebitda * ebitda_m) - net_debt) / shares_m\n",
    "tp_ev_rev    = ((median_ev_rev * revenue_m) - net_debt) / shares_m\n",
    "\n",
    "# Moyenne des 4 méthodes\n",
    "tp_comps = np.mean([tp_pe, tp_fwd_pe, tp_ev_ebitda, tp_ev_rev])\n",
    "\n",
    "print(f'\\n💡 Implied Prices from Comps:')\n",
    "print(f'   P/E method       : ${tp_pe:.2f}')\n",
    "print(f'   Fwd P/E method   : ${tp_fwd_pe:.2f}')\n",
    "print(f'   EV/EBITDA method : ${tp_ev_ebitda:.2f}')\n",
    "print(f'   EV/Revenue method: ${tp_ev_rev:.2f}')\n",
    "print(f'\\n⭐ Blended Comps TP : ${tp_comps:.2f}')\n",
    "print(f'   Current Price    : ${aapl_info[\"currentPrice\"]:.2f}')\n"
   ]
  },
