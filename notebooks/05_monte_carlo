    "vals      = [p5, p25, p50, p75, p95]\n",
    "colors    = ['#e74c3c','#e67e22','#3498db','#27ae60','#9b59b6']\n",
    "\n",
    "bars = ax2.bar(scenarios, vals, color=colors, alpha=0.85, width=0.5)\n",
    "ax2.axhline(y=current_price, color='black', lw=2,\n",
    "            linestyle='--', label=f'Current: ${current_price:.0f}')\n",
    "\n",
    "for bar, val in zip(bars, vals):\n",
    "    ax2.text(bar.get_x() + bar.get_width()/2,\n",
    "             val + 3, f'${val:.0f}',\n",
    "             ha='center', fontweight='bold', fontsize=10)\n",
    "\n",
    "ax2.set_ylabel('Price ($)')\n",
    "ax2.set_title('Scenario Analysis', fontweight='bold')\n",
    "ax2.legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(f'{VIS_DIR}05_monte_carlo.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('✅ Monte Carlo chart sauvegardé!')\n",
    "print(f'\\n📊 Probability AAPL > ${current_price:.0f} : {(prices > current_price).mean():.1%}')\n"
   ]
