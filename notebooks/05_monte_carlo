   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy import stats\n",
    "import yfinance as yf\n",
    "\n",
    "from models.dcf_model import DCFModel, DCFAssumptions\n",
    "\n",
    "VIS_DIR = '../visuals/'\n",
    "\n",
    "# Données Apple\n",
    "info          = yf.Ticker('AAPL').info\n",
    "current_price = info['currentPrice']\n",
    "shares        = info['sharesOutstanding'] / 1e6\n",
    "net_cash      = (info.get('totalCash',0) - info.get('totalDebt',0)) / 1e6\n",
    "base_revenue  = info.get('totalRevenue',0) / 1e6\n",
    "\n",
    "N = 10_000  # nombre de simulations\n",
    "\n",
    "print(f'✅ Setup complet')\n",
    "print(f'   Current Price : ${current_price}')\n",
    "print(f'   Simulations   : {N:,}')\n",
    "print(f'   Base Revenue  : ${base_revenue/1e3:.1f}B')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "6deddace-5ca3-41e0-b923-8bd9789bad35",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ 10,000 simulations completed\n",
      "\n",
      "   Mean Price  : $177.05\n",
      "   Median      : $162.27\n",
      "   Std Dev     : $68.80\n",
      "   5th  pct    : $106.80  ← Bear\n",
      "   25th pct    : $134.59\n",
      "   75th pct    : $200.97\n",
      "   95th pct    : $292.76  ← Bull\n",
      "\n",
      "   P(price > $299) = 4.6%\n"
     ]
    }
   ],
   "source": [
    "np.random.seed(42)\n",
    "\n",
    "# Distribution des paramètres\n",
    "wacc_samples   = np.random.normal(0.09, 0.015, N)   # WACC ~ N(9%, 1.5%)\n",
    "growth_samples = np.random.normal(0.07, 0.02,  N)   # Growth ~ N(7%, 2%)\n",
    "margin_samples = np.random.normal(0.26, 0.02,  N)   # FCF Margin ~ N(26%, 2%)\n",
    "tgr_samples    = np.random.normal(0.03, 0.005, N)   # TGR ~ N(3%, 0.5%)\n",
    "\n",
    "# Clip pour éviter valeurs aberrantes\n",
    "wacc_samples   = np.clip(wacc_samples,   0.05, 0.15)\n",
    "growth_samples = np.clip(growth_samples, 0.00, 0.20)\n",
    "margin_samples = np.clip(margin_samples, 0.15, 0.40)\n",
    "tgr_samples    = np.clip(tgr_samples,    0.01, 0.05)\n",
    "\n",
    "# Lancer les simulations\n",
    "prices = []\n",
    "for i in range(N):\n",
    "    try:\n",
    "        a = DCFAssumptions(\n",
    "            revenue_growth_rates=[growth_samples[i]] * 5,\n",
    "            fcf_margins=[margin_samples[i]] * 5,\n",
    "            terminal_growth_rate=tgr_samples[i],\n",
    "            risk_free_rate=0.045,\n",
    "            equity_risk_premium=0.055,\n",
    "            beta=info.get('beta', 1.25),\n",
    "            shares_outstanding_m=shares,\n",
    "            net_cash_m=net_cash,\n",
    "        )\n",
    "        m = DCFModel(base_revenue, a)\n",
    "        m.compute_wacc()\n",
    "        m._results['wacc'] = wacc_samples[i]\n",
    "        m.project_fcf()\n",
    "        m.discount(wacc_samples[i])\n",
    "        p = m.equity_value_per_share()\n",
    "        if 10 < p < 2000:\n",
    "            prices.append(p)\n",
    "    except:\n",
    "        pass\n",
    "\n",
    "prices = np.array(prices)\n",
    "print(f'✅ {len(prices):,} simulations completed\\n')\n",
    "print(f'   Mean Price  : ${prices.mean():.2f}')\n",
    "print(f'   Median      : ${np.median(prices):.2f}')\n",
    "print(f'   Std Dev     : ${prices.std():.2f}')\n",
    "print(f'   5th  pct    : ${np.percentile(prices, 5):.2f}  ← Bear')\n",
    "print(f'   25th pct    : ${np.percentile(prices, 25):.2f}')\n",
    "print(f'   75th pct    : ${np.percentile(prices, 75):.2f}')\n",
    "print(f'   95th pct    : ${np.percentile(prices, 95):.2f}  ← Bull')\n",
    "print(f'\\n   P(price > ${current_price:.0f}) = {(prices > current_price).mean():.1%}')\n"
   ]
  },
