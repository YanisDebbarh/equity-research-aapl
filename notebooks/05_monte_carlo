    "ax1.axvline(p50, color='#27ae60', lw=2, linestyle='-',  label=f'Base (50%): ${p50:.0f}')\n",
    "ax1.axvline(p95, color='#9b59b6', lw=2, linestyle='--', label=f'Bull (95%): ${p95:.0f}')\n",
