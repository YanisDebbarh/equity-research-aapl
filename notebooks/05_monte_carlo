    "ax1.legend(fontsize=9)\n",
    "\n",
    "# --- Graphique 2 : Bull / Base / Bear ---\n",
    "ax2 = axes[1]\n",
    "scenarios = ['Bear\\n(5th pct)', 'P25', 'Base\\n(Median)',\n",
