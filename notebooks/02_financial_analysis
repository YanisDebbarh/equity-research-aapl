   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "fig.suptitle('Apple Inc. (AAPL) — Financial Analysis', \n",
    "             fontsize=14, fontweight='bold')\n",
    "\n",
    "# --- Graphique 1 : Revenue & Net Income ---\n",
    "ax1 = axes[0]\n",
    "years = metrics.dropna(subset=['Revenue']).index\n",
    "x = np.arange(len(years))\n",
    "w = 0.35\n",
    "\n",
    "ax1.bar(x - w/2, metrics.loc[years, 'Revenue'], \n",
    "        w, label='Revenue', color='#3498db', alpha=0.85)\n",
    "ax1.bar(x + w/2, metrics.loc[years, 'Net_Income'], \n",
    "        w, label='Net Income', color='#27ae60', alpha=0.85)\n",
    "ax1.set_xticks(x)\n",
    "ax1.set_xticklabels(years)\n",
    "ax1.set_ylabel('$B')\n",
    "ax1.set_title('Revenue vs Net Income', fontweight='bold')\n",
    "ax1.legend()\n",
    "\n",
    "# --- Graphique 2 : Margins ---\n",
    "ax2 = axes[1]\n",
    "m = metrics.dropna(subset=['Gross_Margin'])\n",
    "ax2.plot(m.index, m['Gross_Margin']*100,  'o-', color='#3498db', lw=2, label='Gross')\n",
    "ax2.plot(m.index, m['EBITDA_Margin']*100, 'o-', color='#9b59b6', lw=2, label='EBITDA')\n",
    "ax2.plot(m.index, m['Net_Margin']*100,    'o-', color='#27ae60', lw=2, label='Net')\n",
    "ax2.plot(m.index, m['FCF_Margin']*100,    'o-', color='#e74c3c', lw=2, label='FCF')\n",
    "ax2.yaxis.set_major_formatter(mtick.PercentFormatter())\n",
    "ax2.set_title('Margin Evolution', fontweight='bold')\n",
    "ax2.legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(f'{VIS_DIR}01_revenue_margins.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('✅ Graphique sauvegardé → visuals/01_revenue_margins.png')\n"
