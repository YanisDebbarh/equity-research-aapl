    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mtick\n",
    "import os\n",
    "\n",
    "RAW_DIR  = '../data/raw/'\n",
    "VIS_DIR  = '../visuals/'\n",
    "os.makedirs(VIS_DIR, exist_ok=True)\n",
    "\n",
    "# Charger les données\n",
    "income   = pd.read_csv(f'{RAW_DIR}AAPL_income_stmt.csv', index_col=0).T\n",
    "balance  = pd.read_csv(f'{RAW_DIR}AAPL_balance_sheet.csv', index_col=0).T\n",
    "cashflow = pd.read_csv(f'{RAW_DIR}AAPL_cash_flow.csv', index_col=0).T\n",
    "\n",
    "# Nettoyer l'index (garder juste l'année)\n",
    "for df in [income, balance, cashflow]:\n",
    "    df.index = pd.to_datetime(df.index).year\n",
    "\n",
    "print('✅ Données chargées')\n",
    "print(f'   Income Statement : {income.shape}')\n",
    "print(f'   Balance Sheet    : {balance.shape}')\n",
    "print(f'   Cash Flow        : {cashflow.shape}')\n",
    "print('\\n📋 Colonnes Income Statement:')\n",
    "print(list(income.columns[:10]))\n"
   ]
  },
