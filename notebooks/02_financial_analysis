    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "fig.suptitle('Apple Inc. — Cash Flow & Key Ratios', \n",
    "             fontsize=14, fontweight='bold')\n",
    "\n",
    "# --- FCF Bar chart ---\n",
    "ax1 = axes[0]\n",
    "fcf_data = metrics.dropna(subset=['FCF'])\n",
    "colors = ['#27ae60' if v > 0 else '#e74c3c' for v in fcf_data['FCF']]\n",
    "ax1.bar(fcf_data.index, fcf_data['FCF'], color=colors, alpha=0.85)\n",
    "ax1.axhline(y=fcf_data['FCF'].mean(), color='navy', \n",
    "            linestyle='--', lw=1.5, label=f\"Avg: ${fcf_data['FCF'].mean():.0f}B\")\n",
    "ax1.set_ylabel('$B')\n",
    "ax1.set_title('Free Cash Flow', fontweight='bold')\n",
    "ax1.legend()\n",
    "\n",
    "# --- KPI Summary table ---\n",
    "ax2 = axes[1]\n",
    "ax2.axis('off')\n",
    "kpis = [\n",
