   "source": [
    "# Sensitivity table — codée directement ici\n",
    "wacc_range = [0.07, 0.08, 0.09, 0.10, 0.11]\n",
    "tgr_range  = [0.02, 0.025, 0.03, 0.035, 0.04]\n",
    "\n",
    "rows = []\n",
    "for w in wacc_range:\n",
    "    row = {}\n",
    "    for g in tgr_range:\n",
    "        a2 = DCFAssumptions(\n",
    "            revenue_growth_rates=[0.07, 0.08, 0.07, 0.06, 0.05],\n",
    "            fcf_margins=[0.25, 0.26, 0.27, 0.27, 0.28],\n",
    "            terminal_growth_rate=g,\n",
    "            risk_free_rate=0.045,\n",
    "            equity_risk_premium=0.055,\n",
    "            beta=info.get('beta', 1.25),\n",
    "            shares_outstanding_m=shares,\n",
    "            net_cash_m=net_cash,\n",
    "        )\n",
    "        m2 = DCFModel(base_revenue, a2)\n",
    "        m2.compute_wacc()\n",
    "        m2._results['wacc'] = w\n",
    "        m2.project_fcf()\n",
    "        m2.discount(w)\n",
    "        price = m2.equity_value_per_share()\n",
    "        row[f'TGR {g:.1%}'] = round(price, 1)\n",
    "    rows.append(row)\n",
    "\n",
    "sens = pd.DataFrame(rows, index=[f'WACC {w:.0%}' for w in wacc_range])\n",
    "print(f'📊 Sensitivity Table (Current Price: ${current_price:.0f})\\n')\n",
    "print(sens.to_string())\n",
    "print(f'\\n💡 Cellules > ${current_price:.0f} = undervalued')\n",
    "\n"
   ]
