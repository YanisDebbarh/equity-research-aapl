    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mtick\n",
    "import yfinance as yf\n",
    "import os\n",
    "\n",
    "from models.dcf_model import DCFModel, DCFAssumptions\n",
    "\n",
    "VIS_DIR = '../visuals/'\n",
    "RAW_DIR = '../data/raw/'\n",
    "os.makedirs(VIS_DIR, exist_ok=True)\n",
    "\n",
    "# Prix actuel Apple\n",
    "stock         = yf.Ticker('AAPL')\n",
    "info          = stock.info\n",
    "current_price = info['currentPrice']\n",
    "shares        = info['sharesOutstanding'] / 1e6\n",
    "total_cash    = info.get('totalCash', 0) / 1e6\n",
    "total_debt    = info.get('totalDebt', 0) / 1e6\n",
    "net_cash      = total_cash - total_debt\n",
    "base_revenue  = info.get('totalRevenue', 0) / 1e6\n",
    "\n",
    "print(f'✅ Apple Inc. (AAPL)')\n",
    "print(f'   Current Price : ${current_price}')\n",
    "print(f'   Shares (M)    : {shares:,.0f}')\n",
    "print(f'   Net Cash ($M) : ${net_cash:,.0f}')\n",
    "print(f'   LTM Revenue   : ${base_revenue/1e3:.1f}B')\n"
   ]
  },
