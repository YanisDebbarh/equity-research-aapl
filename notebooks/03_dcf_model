    "# Assumptions basées sur les vrais chiffres Apple\n",
    "assumptions = DCFAssumptions(\n",
    "    revenue_growth_rates=[0.07, 0.08, 0.07, 0.06, 0.05],\n",
    "    fcf_margins=[0.25, 0.26, 0.27, 0.27, 0.28],\n",
    "    terminal_growth_rate=0.03,\n",
    "    risk_free_rate=0.045,\n",
    "    equity_risk_premium=0.055,\n",
    "    beta=info.get('beta', 1.25),\n",
    "    shares_outstanding_m=shares,\n",
    "    net_cash_m=net_cash,\n",
    ")\n",
    "\n",
    "# Lancer le modèle\n",
    "model   = DCFModel(base_revenue_m=base_revenue, assumptions=assumptions)\n",
    "results = model.run()\n",
    "model.summary()\n",
    "\n",
    "# Upside / Downside\n",
    "upside = (results['intrinsic_price'] / current_price - 1) * 100\n",
    "print(f'\\n📌 Current Price   : ${current_price:.2f}')\n",
    "print(f'📌 Intrinsic Price : ${results[\"intrinsic_price\"]:.2f}')\n",
    "print(f'📌 Upside/(Down)   : {upside:+.1f}%')\n",
    "if upside > 10:\n",
    "    print('⭐ Rating : BUY')\n",
    "elif upside < -10:\n",
    "    print('⭐ Rating : SELL')\n",
    "else:\n",
    "    print('⭐ Rating : HOLD')\n"
   ]
