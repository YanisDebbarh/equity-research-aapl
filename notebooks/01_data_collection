   "source": [
    "# Pull les peers pour la Comps Analysis\n",
    "PEERS = ['MSFT', 'GOOGL', 'META', 'AMZN', 'NVDA']\n",
    "rows  = []\n",
    "\n",
    "for p in PEERS:\n",
    "    d = yf.Ticker(p).info\n",
    "    rows.append({\n",
    "        'Ticker'    : p,\n",
    "        'Name'      : d.get('shortName'),\n",
    "        'MarketCap' : round(d.get('marketCap', 0)/1e12, 2),\n",
    "        'PE_Ratio'  : d.get('trailingPE'),\n",
    "        'Fwd_PE'    : d.get('forwardPE'),\n",
    "        'EV_EBITDA' : d.get('enterpriseToEbitda'),\n",
    "        'EV_Revenue': d.get('enterpriseToRevenue'),\n",
    "        'Beta'      : d.get('beta'),\n",
    "    })\n",
    "    print(f'  ✅ {p} pulled')\n",
    "\n",
    "peers_df = pd.DataFrame(rows)\n",
    "peers_df.to_csv(f'{RAW_DIR}peers_comps.csv', index=False)\n",
    "print('\\n📊 Peers:')\n",
    "print(peers_df.to_string(index=False))\n"
   ]
