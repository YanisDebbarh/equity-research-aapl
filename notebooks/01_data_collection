    "import yfinance as yf\n",
    "import pandas as pd\n",
    "import os, json\n",
    "\n",
    "TICKER  = 'AAPL'\n",
    "RAW_DIR = '../data/raw/'\n",
    "os.makedirs(RAW_DIR, exist_ok=True)\n",
    "\n",
    "stock = yf.Ticker(TICKER)\n",
    "info  = stock.info\n",
    "\n",
    "print(f\"✅ {info['longName']}\")\n",
    "print(f\"   Prix actuel : ${info['currentPrice']}\")\n",
    "print(f\"   Market Cap  : ${info['marketCap']/1e12:.2f}T\")\n",
    "print(f\"   Secteur     : {info['sector']}\")  "
   ]
  },
