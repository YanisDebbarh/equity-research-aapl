   "source": [
    "# Pull tous les états financiers\n",
    "hist         = stock.history(period='5y')\n",
    "income_stmt  = stock.financials\n",
    "balance_sheet= stock.balance_sheet\n",
    "cash_flow    = stock.cashflow\n",
    "\n",
    "# Sauvegarder dans data/raw/\n",
    "hist.to_csv(f'{RAW_DIR}AAPL_price_history.csv')\n",
    "income_stmt.to_csv(f'{RAW_DIR}AAPL_income_stmt.csv')\n",
    "balance_sheet.to_csv(f'{RAW_DIR}AAPL_balance_sheet.csv')\n",
    "cash_flow.to_csv(f'{RAW_DIR}AAPL_cash_flow.csv')\n",
    "\n",
    "print(f'✅ Prix historiques : {len(hist)} jours')\n",
    "print(f'✅ Income Statement : {income_stmt.shape}')\n",
    "print(f'✅ Balance Sheet    : {balance_sheet.shape}')\n",
    "print(f'✅ Cash Flow        : {cash_flow.shape}')\n",
    "print(f'\\n📁 Fichiers sauvegardés dans data/raw/')\n"
   ]
